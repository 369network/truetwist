# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Supabase)
DATABASE_URL="postgresql://postgres:password@localhost:5432/truetwist"
DIRECT_URL="postgresql://postgres:password@localhost:5432/truetwist"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Apple
APPLE_ID=""
APPLE_SECRET=""

# Redis (Upstash)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY=""

# AI APIs
OPENAI_API_KEY=""

# Runway Gen-3 (Video Generation)
RUNWAY_API_KEY=""
RUNWAY_API_URL="https://api.dev.runwayml.com/v1"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="truetwist-media"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
